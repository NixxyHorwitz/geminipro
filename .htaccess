# Google AI Pro — Security & Routing Rules

# Disable directory listing
Options -Indexes

# Protect sensitive files
<FilesMatch "(\.env|bootstrap\.php|schema\.sql|error_log\.txt|\.git)">
    Order Allow,Deny
    Deny from all
</FilesMatch>


# Block access to src/ and bot/ directories directly
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /googlepro/

    # Block direct access to internal dirs
    RewriteRule ^(src|bot|install|uploads/qris_)/ - [F,L]

    # Block .php in src/ and bot/ from direct browser access
    RewriteCond %{REQUEST_URI} ^/googlepro/(src|bot|install)/
    RewriteRule ^ - [F,L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# PHP settings
<IfModule mod_php8.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
    php_value memory_limit 128M
    php_value max_execution_time 60
</IfModule>

# GZIP Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/jpeg "access plus 30 days"
</IfModule>
